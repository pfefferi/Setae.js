      "result": "Orbinia"
    },
    "optionB": {
      "text": "Without rows of papillae on the ventrum",
      "goTo": "14",
      "result": null
    }
  },
  "14": {
    "step": "14",
    "optionA": {
      "text": "Median and posterior abdominal neuropodia with thick acicula, projecting from the parapodial lobes; branchiae usually present from fifth or sixth segment",
      "goTo": null,
      "result": "Scoloplos (Leodamas)"
    },
    "optionB": {
      "text": "Thick projecting acicula absent; branchiae usually not present before tenth segment",
      "goTo": null,
      "result": "Scoloplos"
    }
